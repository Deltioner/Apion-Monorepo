# --- Shared with the rest of the monorepo (Postgres) ---
DATABASE_URL=postgresql://user:pass@host:5432/postgres

# --- Shop-specific ---
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# --- Better Auth ---
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET=replace-with-32-byte-random-secret
BETTER_AUTH_URL=http://localhost:3002

# Mollie
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend (required — Better Auth's magic-link plugin sends sign-in emails
# through this. Sign up at https://resend.com and verify a sender domain.)
RESEND_API_KEY=re_xxx
EMAIL_FROM=Apion Shop <orders@yourdomain.com>
